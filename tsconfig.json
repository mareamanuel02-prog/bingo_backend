{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",           // ✅ must match moduleResolution
    "moduleResolution": "NodeNext", // ✅ NodeNext resolution for ESM packages
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}